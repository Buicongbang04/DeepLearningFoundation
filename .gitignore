# Generated project outputs (from `python src/train.py` runs)
projects/*/results/*.json
projects/*/results/*.csv
projects/*/results/*.npy
projects/*/results/*.pkl
projects/*/results/*.pt
projects/*/checkpoints/*.pt
!projects/*/results/.gitkeep
!projects/*/checkpoints/.gitkeep

# Generated project figures (notebooks re-create these on every run)
projects/*/figures/*.png
projects/*/figures/*.jpg
projects/*/figures/*.svg
projects/*/figures/*.pdf
!projects/*/figures/.gitkeep

